{
  "name": "location-scouting-web-application",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest",
    "test:migrate": "dotenv -e .env -- npx prisma migrate deploy",
    "test:db:push": "cross-env DATABASE_URL=postgresql://postgres:postgres@localhost:5434/location_scouting_test?schema=public prisma migrate deploy",
    "migrate:all": "npx prisma migrate dev && cross-env DATABASE_URL=postgresql://postgres:postgres@localhost:5434/location_scouting_test?schema=public prisma migrate deploy"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@google-cloud/vision": "^5.3.5",
    "@mui/icons-material": "^7.3.8",
    "@mui/material": "^7.3.8",
    "@prisma/client": "^6.19.2",
    "@vis.gl/react-google-maps": "^1.7.1",
    "better-auth": "^1.6.7",
    "libphonenumber-js": "^1.12.40",
    "minio": "^8.0.6",
    "next": "16.0.0",
    "next-auth": "^5.0.0-beta.31",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4.1.14",
    "@types/googlemaps": "^3.43.3",
    "@types/node": "^20",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/ui": "^4.0.18",
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.0.0",
    "prisma": "^6.19.2",
    "tailwindcss": "^4.1.14",
    "typescript": "^5",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2"
  }
